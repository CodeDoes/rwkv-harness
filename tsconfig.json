  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "skipLibCheck": true,
    "allowArbitraryExtensions": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "express"],
